PROJECT_NAME="OVO.AI"
API_V1_STR="/api/v1"

# Supabase Configurations
SUPABASE_URL="https://your-supabase-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Google OAuth API Settings (Optional in Sandbox Mode)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/auth/callback"

# Gemini & NVIDIA NIM API Keys (Optional in Sandbox Mode)
GEMINI_API_KEY="your-gemini-api-key"
NVIDIA_NIM_API_KEY="your-nvidia-nim-api-key"

# Mock Mode / Sandbox Settings
# Set to 'true' to run fully offline without calling Google OAuth, Google Gmail, or Gemini APIs.
# It will simulate successful auth, sync mock emails, and generate mocked responses.
SANDBOX_MODE="true"
